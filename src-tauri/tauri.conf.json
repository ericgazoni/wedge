{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wedge",
  "version": "0.2.2",
  "identifier": "me.ericgazoni.wedge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wedge",
        "width": 1024,
        "height": 920
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2RTRDRDM5NTI2QzQ1RDMKUldUVFJXeFNPYzNrcGlpcFB0YStzL3hwM1I3anc0ZTI1KzYxVUd5dlRGenl5Q3ZEMlhDSVNpSWcK",
      "endpoints": [
        "https://github.com/ericgazoni/wedge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
